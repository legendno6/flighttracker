# Copy this file to .env and fill in your values.
# Read only by the server-side proxies (server/flightAwareCore.ts,
# server/openSkyCore.ts) — never sent to or bundled into the browser, unlike
# AviationStack's key, which lives in the app's Settings UI instead.

FLIGHTAWARE_API_KEY=

OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
